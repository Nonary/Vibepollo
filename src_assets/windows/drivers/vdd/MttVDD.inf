;
; MttVDD.inf
;

[Version]
PnpLockdown=1
Signature="$Windows NT$"
ClassGUID = {4D36E968-E325-11CE-BFC1-08002BE10318}
Class = Display
ClassVer = 2.0
Provider=%ManufacturerName%
CatalogFile=MttVDD.cat
DriverVer = 05/23/2026,26.5.23.17

[Manufacturer]
%ManufacturerName%=Standard,NTamd64

[Standard.NTamd64]
%DeviceName%=MyDevice_Install, Root\MttVDD ; TODO: edit hw-id
%DeviceName%=MyDevice_Install, MttVDD      ; TODO: edit hw-id, this hardware if is used by the IddSampleApp.exe

[SourceDisksFiles]
MttVDD.dll=1

[SourceDisksNames]
1 = %DiskName%

; =================== UMDF Device ==================================

[MyDevice_Install.NT]
CopyFiles=UMDriverCopy

[MyDevice_Install.NT.Interfaces]
AddInterface={bc4e6328-82d7-4844-9455-0b1b708f498f},,VddControl_InterfaceInstall

[MyDevice_Install.NT.hw]
AddReg = MyDevice_HardwareDeviceSettings

[MyDevice_HardwareDeviceSettings]
HKR,, "UpperFilters",  %REG_MULTI_SZ%, "IndirectKmd"
HKR, "WUDF", "DeviceGroupId", %REG_SZ%, "MttVDDGroup" ; TODO: edit driver group name, see README.md for more info

[MyDevice_Install.NT.Services]
AddService=WUDFRd,0x000001fa,WUDFRD_ServiceInstall

[MyDevice_Install.NT.Wdf]
UmdfService=MttVDD,MttVDD_Install
UmdfServiceOrder=MttVDD
UmdfKernelModeClientPolicy = AllowKernelModeClients

[MttVDD_Install]
UmdfLibraryVersion=2.25.0
ServiceBinary=%12%\UMDF\MttVDD.dll
UmdfExtensions = IddCx0102

[VddControl_InterfaceInstall]
AddReg=VddControl_InterfaceSecurity

[VddControl_InterfaceSecurity]
HKR,,Security,,"D:P(A;;GA;;;SY)(A;;GA;;;BA)(A;;GRGW;;;AU)"

[WUDFRD_ServiceInstall]
DisplayName = %WudfRdDisplayName%
ServiceType = 1
StartType = 3
ErrorControl = 1
ServiceBinary = %12%\WUDFRd.sys

[DestinationDirs]
UMDriverCopy=12,UMDF ; copy to drivers\umdf

[UMDriverCopy]
MttVDD.dll

; =================== Generic ==================================

[Strings]
ManufacturerName="MikeTheTech" ; TODO: Replace with your manufacturer name
DiskName = "MttVDD Installation Disk" ; TODO: Replace with driver disk name
WudfRdDisplayName="Windows Driver Foundation - User-mode Driver Framework Reflector"
DeviceName="Virtual Display Driver" ; TODO: Replace with correct device name

REG_MULTI_SZ  = 0x00010000
REG_SZ        = 0x00000000
REG_EXPAND_SZ = 0x00020000
REG_DWORD     = 0x00010001
