if(DEFINED ENV{SIGNPATH_API_TOKEN} AND NOT "$ENV{SIGNPATH_API_TOKEN}" STREQUAL "")
  message(STATUS "Rebuilding uninstall.exe before SignPath signing")
  execute_process(
    COMMAND powershell -NoProfile -ExecutionPolicy Bypass
            -File "@CMAKE_SOURCE_DIR@/packaging/windows/bootstrapper/build_bootstrapper.ps1"
            -BuildDir "@CMAKE_BINARY_DIR@"
            -UninstallOnly
            -OutputName "uninstall.exe"
            -DisableSignPath
    RESULT_VARIABLE _uninstaller_build_result
  )
  if(NOT _uninstaller_build_result EQUAL 0)
    message(FATAL_ERROR "Failed to rebuild uninstall.exe before SignPath signing (exit code ${_uninstaller_build_result})")
  endif()

  execute_process(
    COMMAND "@CMAKE_COMMAND@" -E copy_if_different
            "@CMAKE_BINARY_DIR@/cpack_artifacts/uninstall.exe"
            "@CMAKE_BINARY_DIR@/uninstall.exe"
    RESULT_VARIABLE _uninstaller_copy_result
  )
  if(NOT _uninstaller_copy_result EQUAL 0)
    message(FATAL_ERROR "Failed to copy rebuilt uninstall.exe before SignPath signing (exit code ${_uninstaller_copy_result})")
  endif()

  message(STATUS "Signing uninstall.exe with SignPath before WiX packaging")
  execute_process(
    COMMAND powershell -NoProfile -ExecutionPolicy Bypass
            -File "@CMAKE_SOURCE_DIR@/scripts/signpath_sign.ps1"
            -InputArtifactPath "@CMAKE_BINARY_DIR@/uninstall.exe"
            -OutputArtifactPath "@CMAKE_BINARY_DIR@/uninstall.exe"
            -InstallModuleIfMissing
            -SkipIfMissingToken
    RESULT_VARIABLE _signpath_result
  )
  if(NOT _signpath_result EQUAL 0)
    message(FATAL_ERROR "SignPath signing failed for uninstall.exe (exit code ${_signpath_result})")
  endif()
else()
  message(STATUS "SIGNPATH_API_TOKEN is not set; skipping SignPath signing for uninstall.exe")
endif()
